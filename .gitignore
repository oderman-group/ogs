# ODERMAN GROUP SAS - .gitignore

# Archivos del sistema
.DS_Store
Thumbs.db
desktop.ini

# Archivos de editor
.vscode/
.idea/
*.swp
*.swo
*~

# Archivos temporales
*.tmp
*.log
*.cache

# Archivos de configuración local
config.local.php
.env
.env.local

# Archivos de backup
*.bak
*.backup
*.old

# Archivos comprimidos (excepto los necesarios)
*.zip
*.tar
*.tar.gz
*.rar

# Node modules (si se usa npm)
node_modules/
package-lock.json

# Archivos de desarrollo
*.dev.php
*.test.php
